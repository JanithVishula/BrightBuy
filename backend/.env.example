# ===================================================================
# Backend environment variables
# Copy this file to .env for local development. NEVER commit a real .env.
# ===================================================================

# Server
PORT=5001
NODE_ENV=development

# Local MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=brightbuy

# Auth — REQUIRED. The server refuses to start without it.
# Generate a strong value, e.g.: openssl rand -base64 48
JWT_SECRET=

# CORS — comma-separated list of allowed frontend origins.
# Defaults to localhost:3000/3001 if unset.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
