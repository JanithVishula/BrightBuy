# ===================================================================
# Backend environment variables
# Copy this file to .env for local dev, and set the same keys in your
# host's dashboard (e.g. Render) for production. NEVER commit a real .env.
# ===================================================================

# Server
PORT=5001
NODE_ENV=development

# Database (MySQL). Works with any host: local, Aiven, Railway, etc.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=brightbuy

# SSL — set DB_SSL=true for managed hosts that require it (e.g. Aiven).
# Leave false for a local MySQL.
DB_SSL=false
# Set to true only if you provide a trusted CA cert; false is fine for Aiven.
DB_SSL_REJECT_UNAUTHORIZED=false

# Auth — REQUIRED. The server refuses to start without it.
# Generate a strong value: openssl rand -base64 48
JWT_SECRET=

# CORS — comma-separated list of allowed frontend origins.
# Local dev defaults to localhost:3000/3001 if unset.
# Production example: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Cloudinary (product image uploads). If unset, uploads fall back to local
# disk (ephemeral on cloud hosts — images vanish on redeploy). Get these from
# your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
